{
  "name": "astrobook-monorepo",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "description": "Astrobook monorepo",
  "license": "MIT",
  "scripts": {
    "dev": "turbo watch --filter example-playground dev",
    "postinstall": "pnpm --filter=./packages/ui build",
    "build": "turbo run build --concurrency=1",
    "build:package": "turbo build --filter='./packages/*' --concurrency=1",
    "lint": "eslint .",
    "fix": "manypkg fix && eslint --fix . && prettier --write .",
    "prepublishOnly": "pnpm run build",
    "test": "vitest",
    "test:install": "playwright install --with-deps",
    "test:install:chromium": "playwright install --with-deps chromium",
    "test:install:firefox": "playwright install --with-deps firefox",
    "test:install:webkit": "playwright install --with-deps webkit",
    "test:e2e": "playwright test",
    "typecheck": "tsc --build .",
    "change": "changeset",
    "ci:version": "changeset version && pnpm install --no-frozen-lockfile",
    "ci:publish": "pnpm run build:package && pnpm publish --access public -r --no-git-checks --tag latest",
    "ci:publish-dev": "pnpm run build:package && pkg-pr-new publish './packages/*' --template ./examples/playground --pnpm"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@changesets/types": "^6.1.0",
    "@manypkg/cli": "^0.25.1",
    "@ocavue/eslint-config": "^4.3.5",
    "@playwright/test": "^1.58.2",
    "@types/node": "^22.15.29",
    "eslint": "^10.0.3",
    "pkg-pr-new": "^0.0.66",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.8.20",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.1.0"
  },
  "pnpm": {
    "overrides": {
      "astrobook@*": "workspace:*"
    }
  },
  "renovate": {
    "extends": [
      "github>ocavue/config-renovate"
    ]
  }
}
