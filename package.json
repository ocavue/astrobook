{
  "name": "astrobook-monorepo",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "description": "Astrobook monorepo",
  "license": "MIT",
  "scripts": {
    "dev": "turbo watch --filter example-playground dev",
    "postinstall": "pnpm --filter=./packages/ui build",
    "build": "turbo run build --concurrency=1",
    "build:package": "turbo build --filter='./packages/*' --concurrency=1",
    "lint": "pnpm lint:eslint && pnpm lint:prettier",
    "lint:eslint": "eslint --max-warnings=0",
    "lint:prettier": "prettier --check .",
    "fix": "pnpm fix:prettier && pnpm fix:eslint && pnpm fix:manypkg",
    "fix:eslint": "eslint --fix --max-warnings=0",
    "fix:prettier": "prettier --write .",
    "fix:manypkg": "manypkg fix",
    "prepublishOnly": "pnpm run build",
    "test": "vitest",
    "test:install": "playwright install --with-deps",
    "test:install:chromium": "playwright install --with-deps chromium",
    "test:install:firefox": "playwright install --with-deps firefox",
    "test:install:webkit": "playwright install --with-deps webkit",
    "test:e2e": "playwright test",
    "typecheck": "tsc --build .",
    "change": "changeset",
    "ci:version": "changeset version && pnpm install --no-frozen-lockfile",
    "ci:publish": "pnpm run build:package && pnpm publish --access public -r --no-git-checks --tag latest",
    "ci:publish-dev": "pnpm run build:package && pkg-pr-new publish './packages/*' --template ./examples/playground --pnpm"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@changesets/types": "^6.1.0",
    "@manypkg/cli": "^0.25.1",
    "@ocavue/eslint-config": "^4.8.1",
    "@playwright/test": "^1.61.0",
    "@types/node": "^22.19.17",
    "eslint": "^10.5.0",
    "pkg-pr-new": "^0.0.75",
    "playwright": "^1.61.0",
    "prettier": "^3.8.4",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "turbo": "^2.9.18",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.9"
  }
}
