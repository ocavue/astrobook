---
import '../style.css'
import './layout.css'
import Sidebar from './sidebar.astro'
import SidebarResizeHandle from './sidebar-resize-handle.astro'
import { ThemeScript } from 'astro-theme-toggle/components'
import CustomHead from 'virtual:astrobook/components/head.mjs'
import config from 'virtual:astrobook/global-config.mjs'

import { ClientRouter } from 'astro:transitions'

// Important that this is the last import so it can override built-in styles.
import 'virtual:astrobook/user-css.mjs'

interface Props {
  story: string | undefined
  hasSidebar: boolean
}

const hasSidebar = Astro.props.hasSidebar ?? true
const DEFAULT_SIDEBAR_WIDTH = 300
const DEFAULT_SIDEBAR_RESIZING = false
---

<html
  lang="en"
  class=":uno: box-border h-full max-h-screen overflow-hidden"
  data-astrobook-root
  data-active-story={Astro.props.story ?? ''}
  data-sidebar-width={DEFAULT_SIDEBAR_WIDTH}
  data-sidebar-resizing={DEFAULT_SIDEBAR_RESIZING ? '' : undefined}
>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{config.title}</title>
    <ThemeScript />
    <script src="./theme-message.ts"></script>
    <script src="./sidebar-active-story.ts"></script>
    <CustomHead />
    <ClientRouter fallback="none" />
    <style is:global>
      :root {
        --astrobook-sidebar-width: attr(data-sidebar-width px);
      }
      :root[data-sidebar-resizing] {
        cursor: ew-resize;
        user-select: none;
      }
      #astrobook-sidebar {
        width: var(--astrobook-sidebar-width);
        min-width: 100px;
        max-width: calc(100vw - 100px);
      }
    </style>
    <script is:inline>
      ;(() => {
        const STORAGE_KEY = 'astrobook-sidebar-width'
        const restoreWidth = () => {
          const width = parseFloat(localStorage.getItem(STORAGE_KEY) || '')
          if (width) {
            document.documentElement.dataset.sidebarWidth = String(width)
          }
        }

        restoreWidth()
        document.addEventListener('astro:after-swap', restoreWidth)
      })()
    </script>
  </head>
  <body
    class=":uno: m-0 box-border flex max-h-full min-h-full flex-row items-stretch justify-start p-0"
  >
    {
      hasSidebar && (
        <>
          <div
            id="astrobook-sidebar"
            class=":uno: flex shrink-0 flex-col border-0 border-r border-solid border-gray-200 bg-gray-50 dark:border-gray-700 dark:bg-zinc-900"
          >
            <Sidebar story={Astro.props.story} />
          </div>
          <SidebarResizeHandle />
        </>
      )
    }
    {
      /* 
      Use `transition:animate="none"` here because we don't want the fade animation 
      when switching between stories. Sadly this also removes the animation when toggling the light/dark theme.
      */
    }
    <main
      class=":uno: box-border flex-1 overflow-auto"
      transition:name="astrobook-main"
      transition:animate="none"
    >
      <slot />
    </main>
  </body>
</html>
