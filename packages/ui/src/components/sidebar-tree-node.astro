---
import type { TreeNode } from './build-tree'
import config from 'virtual:astrobook/global-config.mjs'
import { buildPath } from './build-path'

interface Props {
  node: TreeNode
}

const { node } = Astro.props

// We will update the active state using sidebar-active-story.ts, but we need to set an initial state here so that
// UnoCSS can scan both active and inactive class names.
const active = false
---

{
  node.type === 'directory' && (
    <astrobook-sidebar-node class=":uno: contents">
      <details
        open
        data-astrobook-collapsible
        data-id={`dir:${node.name}`}
        data-search-text={node.searchText}
      >
        <summary
          class:list={[
            'astrobook-sidebar-link',
            'astrobook-sidebar-collapsible-link',
            'astrobook-focus-ring',
          ]}
        >
          <span
            data-astrobook-chevron
            class=":uno: i-fluent-chevron-down-16-regular inline-block size-3.5 shrink-0 text-gray-400 dark:text-gray-500"
          />
          <span>{node.name}</span>
        </summary>
        <div class=":uno: flex flex-col gap-0.5 pl-3">
          {node.children.map((child) => (
            <Astro.self node={child} />
          ))}
        </div>
      </details>
    </astrobook-sidebar-node>
  )
}

{
  node.type === 'module' && (
    <astrobook-sidebar-node class=":uno: contents">
      <details
        open
        data-astrobook-collapsible
        data-id={`module:${node.id}`}
        data-search-text={node.searchText}
      >
        <summary
          class:list={[
            'astrobook-sidebar-link',
            'astrobook-sidebar-collapsible-link',
            'astrobook-focus-ring',
          ]}
        >
          <span class=":uno: i-fluent-collections-empty-16-regular inline-block size-3.5 shrink-0 text-gray-400 dark:text-gray-500" />
          <span>{node.name}</span>
        </summary>
        <div class=":uno: flex flex-col gap-0.5 pl-3">
          {node.children.map((child) => (
            <Astro.self node={child} />
          ))}
        </div>
      </details>
    </astrobook-sidebar-node>
  )
}

{
  node.type === 'story' && (
    <a
      href={buildPath(config.dashboardBase, node.id)}
      data-astrobook-story-link
      data-story-id={node.id}
      data-search-text={node.searchText}
      class:list={[
        'astrobook-sidebar-link',
        'astrobook-focus-ring',
        active
          ? 'astrobook-sidebar-story-link-active'
          : 'astrobook-sidebar-story-link-inactive',
      ]}
    >
      <span class=":uno: i-fluent-diamond-16-regular inline-block size-3.5 shrink-0 text-gray-400 dark:text-gray-500" />
      <span>{node.name}</span>
    </a>
  )
}

<style>
  /*
   * TODO: Replace with UnoCSS `details-content:` variant once supported.
   * https://github.com/unocss/unocss/issues/5137
   */
  details[data-astrobook-collapsible] {
    interpolate-size: allow-keywords;
  }

  details[data-astrobook-collapsible]::details-content {
    height: 0;
    overflow: clip;
    transition:
      height 150ms ease-out,
      content-visibility 150ms ease-out allow-discrete;
  }

  details[data-astrobook-collapsible][open]::details-content {
    height: auto;
  }

  [data-astrobook-chevron] {
    transform: rotate(-90deg);
    transition: transform 150ms ease-out;
  }

  details[data-astrobook-collapsible][open]
    > summary
    > [data-astrobook-chevron] {
    transform: rotate(0deg);
  }
</style>
